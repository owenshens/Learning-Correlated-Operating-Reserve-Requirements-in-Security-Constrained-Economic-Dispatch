\label{tab:results}
\centering
\begin{tabular}{lcccc}
\toprule
\textbf{Method} & \textbf{Cost (\$/hr)} & \textbf{Reserve (MW)} & \textbf{Cal.\ Cov.} & \textbf{Test Cov.\ (95\% CI)} \\
\midrule
Independent & 99{,}944 & 1{,}563 & 0.950 & 0.986 [0.982, 0.989] \\
Sample Covariance & 100{,}012 & 1{,}572 & 0.950 & 0.980 [0.975, 0.984] \\
Learned (Static) & 95{,}471 & 956 & 0.950 & 0.967 [0.960, 0.972] \\
