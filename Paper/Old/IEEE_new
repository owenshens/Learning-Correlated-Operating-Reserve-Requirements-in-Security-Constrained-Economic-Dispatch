\section{Supporting Definitions and Lemmas}
\label{app:supporting}

\begin{definition}[Clarke Subdifferential]\label{def:clarke}
Let $h:\R^p\to\R$ be locally Lipschitz. The Clarke subdifferential of $h$ at $x$ is
\[
\clsubd h(x)
:=\conv\Big\{\lim_{k\to\infty}\nabla h(x_k)\ :\ x_k\to x,\ h \text{ differentiable at }x_k\Big\}.
\]
Any $g\in\clsubd h(x)$ is called a Clarke subgradient of $h$ at $x$.
\end{definition}

\begin{lemma}[Support Function Scaling]\label{lem:support-scaling}
If $C \subseteq \R^d$ is nonempty and $\rho > 0$, then
\begin{equation}\label{eq:sigma-scale}
\sigma_{\rho C}(\bw) = \rho \cdot \sigma_C(\bw) \quad \forall \bw \in \R^d.
\end{equation}
\end{lemma}

\begin{proof}
By definition, $\sigma_{\rho C}(\bw) = \sup_{\bu \in \rho C} \ip{\bw}{\bu} = \sup_{\bm{v} \in C} \ip{\bw}{\rho \bm{v}} = \rho \sup_{\bm{v} \in C} \ip{\bw}{\bm{v}} = \rho \sigma_C(\bw)$.
\end{proof}

\begin{lemma}[Strong Duality at Slater Points]\label{lem:strong-duality}
Under Assumption~\ref{asm:slater}, strong duality holds at $(\btheta,\rho)$:
\[
V(\btheta,\rho)=\max_{\bmu\ge 0} q(\bmu;\btheta,\rho),
\]
and the maximum is attained (i.e., $\cM^*(\btheta,\rho)\neq\emptyset$).
Here $q(\bmu;\btheta,\rho) := \inf_{\bx\in\R^{n_x}} \cL(\bx,\bmu;\btheta,\rho)$ is the dual function,
with Lagrangian
$\cL(\bx,\bmu;\btheta,\rho)= f(\bx) + I_{\cX}(\bx) + \sum_{j=1}^m \mu_j [a_j(\bx) + \sigma_{\cU_{\btheta,\rho}}(\bw_j) - b_j]$
and $\bmu\in\R_+^m$.
\end{lemma}

\begin{proof}[Proof of Proposition~\ref{prop:profiling}]
(i) Fix $\btheta$ and let $0 < \rho_1 \leq \rho_2$. Since $\cU_{\btheta,\rho_1} \subseteq \cU_{\btheta,\rho_2}$, the support function satisfies $\sigma_{\cU_{\btheta,\rho_1}}(\bw_j) \leq \sigma_{\cU_{\btheta,\rho_2}}(\bw_j)$. Thus the feasible region of~\eqref{eq:robust} shrinks as $\rho$ increases, and therefore $V(\btheta,\rho_1) \leq V(\btheta,\rho_2)$ (with the convention $+\infty$ for infeasibility).

(ii) By definition of $\rho_P(\btheta)$ as the right $\tau$-quantile, $F_{\btheta}(\rho) \geq \tau$ holds if and only if $\rho \geq \rho_P(\btheta)$.

(iii) For any feasible $(\btheta, \rho)$ in~\eqref{eq:bilevel}, we have $\rho \geq \rho_P(\btheta)$ by (ii). By (i), $V(\btheta,\rho) \geq V(\btheta,\rho_P(\btheta)) = J_P(\btheta)$. Thus the optimal choice for each $\btheta$ is $\rho = \rho_P(\btheta)$.
\end{proof}

\begin{lemma}[Robust Counterpart of Absolute-Value Constraints]\label{lem:robust-abs}
Let $\cU\subseteq\R^d$ be nonempty and let $w\in\R^d$. For any scalar $f\in\R$,
\[
\sup_{u\in\cU} \big| f + \ip{w}{u} \big|
\le F
\]
is equivalent to the pair of inequalities
\begin{equation}\label{eq:robust-abs-pair}
f + \sigma_{\cU}(w)\le F,
\qquad
-f + \sigma_{\cU}(-w)\le F.
\end{equation}
If $\cU$ is centrally symmetric (i.e., $\cU=-\cU$), then $\sigma_{\cU}(-w)=\sigma_{\cU}(w)$ and
\eqref{eq:robust-abs-pair} is equivalent to
\[
|f| + \sigma_{\cU}(w)\le F.
\]
\end{lemma}

\begin{proof}
The robust inequality is equivalent to the conjunction of
$f+\ip{w}{u}\le F$ for all $u\in\cU$ and $-(f+\ip{w}{u})\le F$ for all $u\in\cU$.
Taking suprema over $u\in\cU$ yields \eqref{eq:robust-abs-pair}.
If $\cU=-\cU$, then $\sigma_{\cU}(-w)=\sup_{u\in\cU}\ip{-w}{u}=\sup_{u\in\cU}\ip{w}{-u}=\sigma_{\cU}(w)$,
and the pair reduces to $f+\sigma_{\cU}(w)\le F$ and $-f+\sigma_{\cU}(w)\le F$, i.e., $|f|+\sigma_{\cU}(w)\le F$.
\end{proof}

\section{Proof of Envelope Gradient Formula}
\label{app:envelope-proof}

\begin{proof}[Proof of Theorem~\ref{thm:envelope}]
Fix $(\btheta,\rho)$ with $V(\btheta,\rho)<+\infty$ and let $\bmu^*\in\cM^*(\btheta,\rho)$.

\emph{Part~(a).}
For any $\btheta'$,
\[
V(\btheta',\rho)=\max_{\bmu\ge 0} q(\bmu;\btheta',\rho)\ge q(\bmu^*;\btheta',\rho).
\]
Using the dual decomposition
\[
q(\bmu;\btheta,\rho)
=\tilde q(\bmu)+\sum_{j=1}^m \mu_j(\sigma_{\cU_{\btheta,\rho}}(\bw_j)-b_j),
\]
we have
\[
q(\bmu^*;\btheta',\rho)-q(\bmu^*;\btheta,\rho)
=\sum_{j=1}^m \mu_j^*\big(\sigma_{\cU_{\btheta',\rho}}(\bw_j)-\sigma_{\cU_{\btheta,\rho}}(\bw_j)\big).
\]
Since $q(\bmu^*;\btheta,\rho)=V(\btheta,\rho)$ and each support function term is differentiable in $\btheta$
(Assumption~\ref{asm:sigma-diff}), we obtain
\[
V(\btheta',\rho)-V(\btheta,\rho)
\ge \ip{\sum_{j=1}^m \mu_j^* \nabla_{\btheta}\sigma_{\cU_{\btheta,\rho}}(\bw_j)}{\btheta'-\btheta}
+ o(\|\btheta'-\btheta\|),
\]
which implies $\bg_{\btheta}(\btheta,\rho;\bmu^*)\in \clsubd_{\btheta}V(\btheta,\rho)$ by Definition~\ref{def:clarke}.
The differentiable case under uniqueness is standard: the Clarke subdifferential reduces to a singleton, equal to the gradient.

\emph{Part~(b).}
By Assumption~\ref{asm:gauge}, $\cU_{\btheta,\rho}=\rho\,\cU_{\btheta,1}$ and hence
$\sigma_{\cU_{\btheta,\rho}}(\bw_j)=\rho\,\sigma_{\cU_{\btheta,1}}(\bw_j)$.
Therefore $q(\bmu;\btheta,\rho)$ is affine in $\rho$:
\[
q(\bmu;\btheta,\rho)
=\tilde q(\bmu)-\sum_{j=1}^m \mu_j b_j
+\rho\sum_{j=1}^m \mu_j\sigma_{\cU_{\btheta,1}}(\bw_j).
\]
The same argument as Part~(a), applied to the $\rho$ variable, yields the Clarke subgradient statement for $g_\rho$.
\end{proof}

\section{Proofs of Statistical Results}
\label{app:statistical-proofs}

The following intermediate results are used in the proofs of Theorems~\ref{thm:true-oracle-grad} and~\ref{thm:consistency-eps}.

\begin{lemma}[Implicit Derivative of Quantile Map]\label{lem:quantile-deriv}
Under Assumption~\ref{asm:quantile-reg}, $\rho_P$ is differentiable at $\btheta$ with
\begin{equation}\label{eq:quantile-ift}
\nabla_{\btheta} \rho_P(\btheta) = -\frac{\nabla_{\btheta} F_{\btheta}(\rho_P(\btheta))}{f_{\btheta}(\rho_P(\btheta))}.
\end{equation}
\end{lemma}

\begin{proof}
Define $G(\btheta,r) := F_{\btheta}(r) - \tau$. By definition, $G(\btheta, \rho_P(\btheta)) = 0$ and $\partial_r G = f_{\btheta}(\rho_P(\btheta)) > 0$. The implicit function theorem yields~\eqref{eq:quantile-ift}.
\end{proof}

\begin{assumption}[Smoothing Function]\label{asm:smoothing}
Let $\Phi: \R \to [0,1]$ be continuously differentiable, nondecreasing, with $\lim_{t \to -\infty} \Phi(t) = 0$ and $\lim_{t \to +\infty} \Phi(t) = 1$. Let $\varphi(t) := \Phi'(t)$ be bounded and uniformly continuous on $\R$.
\end{assumption}

\begin{assumption}[Score Differentiability]\label{asm:score-diff}
For each $\bu \in \R^d$, the map $\btheta \mapsto s_{\btheta}(\bu)$ is continuously differentiable. There exists an integrable function $M(U)$ such that $\norm{\nabla_{\btheta} s_{\btheta}(U)} \leq M(U)$ almost surely.
\end{assumption}

\begin{lemma}[Smoothed CDF Derivatives]\label{lem:smoothed-derivatives}
Under Assumptions~\ref{asm:smoothing} and~\ref{asm:score-diff}, for each $\varepsilon > 0$:
\begin{align}
\partial_r F_{\btheta,\varepsilon}(r) &= \frac{1}{\varepsilon} \E\left[\varphi\left(\frac{r - s_{\btheta}(U)}{\varepsilon}\right)\right] \label{eq:dFr} \\
\nabla_{\btheta} F_{\btheta,\varepsilon}(r) &= -\frac{1}{\varepsilon} \E\left[\varphi\left(\frac{r - s_{\btheta}(U)}{\varepsilon}\right) \nabla_{\btheta} s_{\btheta}(U)\right]. \label{eq:dFtheta}
\end{align}
\end{lemma}

\begin{proof}
Differentiation under the expectation is justified by dominated convergence using boundedness of $\varphi$ and integrability domination of $\nabla_{\btheta} s_{\btheta}(U)$.
\end{proof}

\begin{lemma}[Smoothed Quantile Sensitivity]\label{lem:smoothed-quantile-deriv}
Under Assumptions~\ref{asm:smoothing}, \ref{asm:score-diff}, and assuming $\partial_r F_{\btheta,\varepsilon}(\rho_{P,\varepsilon}(\btheta)) > 0$:
\begin{equation}\label{eq:rhoeps-deriv}
\nabla_{\btheta} \rho_{P,\varepsilon}(\btheta) = \frac{\E\left[\varphi\left(\frac{\rho_{P,\varepsilon}(\btheta) - s_{\btheta}(U)}{\varepsilon}\right) \nabla_{\btheta} s_{\btheta}(U)\right]}{\E\left[\varphi\left(\frac{\rho_{P,\varepsilon}(\btheta) - s_{\btheta}(U)}{\varepsilon}\right)\right]}.
\end{equation}
\end{lemma}

\begin{proof}
Apply the implicit function theorem to $G(\btheta,r) = F_{\btheta,\varepsilon}(r) - \tau$ and substitute Lemma~\ref{lem:smoothed-derivatives}. The factor $1/\varepsilon$ cancels in the ratio.
\end{proof}

\begin{remark}[Interpretation]
The formula~\eqref{eq:rhoeps-deriv} is a weighted average of $\nabla_{\btheta} s_{\btheta}(U)$ with weights $\varphi((\rho_{P,\varepsilon} - s_{\btheta}(U))/\varepsilon)$ concentrated on samples near the quantile boundary. This is a soft analogue of the boundary conditional expectation $\E[\nabla_{\btheta} s_{\btheta}(U) \mid s_{\btheta}(U) = \rho_P(\btheta)]$.
\end{remark}

The full regularity conditions for Theorem~\ref{thm:consistency-eps} are:
\begin{enumerate}
\item[(A1)] $U_1,\ldots,U_{n_{\mathrm{tune}}}$ are i.i.d.\ from $P$.
\item[(A2)] Assumptions~\ref{asm:smoothing} and~\ref{asm:score-diff} hold, $\varphi$ is uniformly continuous on $\R$, and strictly positive: $\varphi(t)>0$ for all $t\in\R$.
\item[(A3)] The population smoothed CDF $r\mapsto F_{\btheta,\varepsilon}(r)$ is strictly increasing in a neighborhood of
$\rho_{P,\varepsilon}(\btheta)$ and $\partial_r F_{\btheta,\varepsilon}(\rho_{P,\varepsilon}(\btheta))>0$.
\item[(A4)] The robust value function is differentiable at $(\btheta,\rho_{P,\varepsilon}(\btheta))$ with respect to $\btheta$ and $\rho$,
and the dual optimizer is unique in a neighborhood of $(\btheta,\rho_{P,\varepsilon}(\btheta))$ so that
$\bmu^*(\btheta,\rho)$ is well-defined and continuous there.
\item[(A5)] For each $j$, $\nabla_{\btheta}\sigma_{\cU_{\btheta,\rho}}(\bw_j)$ is continuous in $(\btheta,\rho)$ in a neighborhood of
$(\btheta,\rho_{P,\varepsilon}(\btheta))$.
\end{enumerate}

\begin{proof}[Proof of Theorem~\ref{thm:conformal} (Split Conformal Coverage)]
Condition on $\hat{\btheta}$. Under Assumption~\ref{asm:exchange}, the $(n_{\mathrm{cal}}+1)$-tuple
$(U_1,\ldots,U_{n_{\mathrm{cal}}},U_{\mathrm{new}})$ is exchangeable conditional on $\hat{\btheta}$, hence the
scores
\[
S_1:=s_{\hat{\btheta}}(U_1),\ \ldots,\ S_{n_{\mathrm{cal}}}:=s_{\hat{\btheta}}(U_{n_{\mathrm{cal}}}),\
S_{\mathrm{new}}:=s_{\hat{\btheta}}(U_{\mathrm{new}})
\]
are exchangeable conditional on $\hat{\btheta}$.

To avoid any ambiguity due to ties, introduce auxiliary random variables
$V_1,\ldots,V_{n_{\mathrm{cal}}},V_{\mathrm{new}} \stackrel{\mathrm{i.i.d.}}{\sim}\mathrm{Unif}(0,1)$
independent of everything else, and define the \emph{randomized rank} $R$ of the pair
$(S_{\mathrm{new}},V_{\mathrm{new}})$ among the $(n_{\mathrm{cal}}+1)$ pairs
\[
(S_1,V_1),\ldots,(S_{n_{\mathrm{cal}}},V_{n_{\mathrm{cal}}}),\ (S_{\mathrm{new}},V_{\mathrm{new}})
\]
under lexicographic ordering: $(s,v)\prec(s',v')$ if either $s<s'$ or $s=s'$ and $v<v'$.
Because the $V$'s are continuous, all pairs are distinct almost surely, and since the pairs are exchangeable
conditional on $\hat{\btheta}$, the randomized rank satisfies
\[
\Prob(R=r\mid \hat{\btheta})=\frac{1}{n_{\mathrm{cal}}+1},\qquad r=1,\ldots,n_{\mathrm{cal}}+1.
\]

Let $k=\lceil(n_{\mathrm{cal}}+1)\tau\rceil$ and let $S_{(k)}$ denote the $k$-th order statistic of
$S_1,\ldots,S_{n_{\mathrm{cal}}}$, with the convention $S_{(n_{\mathrm{cal}}+1)}:=+\infty$ and
$\hat\rho_\tau:=S_{(k)}$ as in~\eqref{eq:conformal-rho}.

We claim that the event $\{R\le k\}$ implies $\{S_{\mathrm{new}}\le S_{(k)}\}$.
Indeed, if $S_{\mathrm{new}}>S_{(k)}$ then at least $k$ of the calibration scores satisfy
$S_i \le S_{(k)} < S_{\mathrm{new}}$, hence in lexicographic order all those $k$ pairs satisfy
$(S_i,V_i)\prec(S_{\mathrm{new}},V_{\mathrm{new}})$ regardless of the $V$'s, forcing $R\ge k+1$.
Taking the contrapositive yields $\{R\le k\}\subseteq\{S_{\mathrm{new}}\le S_{(k)}\}$.

Therefore, conditional on $\hat{\btheta}$,
\[
\Prob(S_{\mathrm{new}}\le \hat\rho_\tau \mid \hat{\btheta})
=\Prob(S_{\mathrm{new}}\le S_{(k)} \mid \hat{\btheta})
\ \ge\ \Prob(R\le k\mid \hat{\btheta})
=\frac{k}{n_{\mathrm{cal}}+1}
\ \ge\ \tau,
\]
where the last inequality holds by the definition of $k=\lceil(n_{\mathrm{cal}}+1)\tau\rceil$.
Finally, taking expectations over $\hat{\btheta}$ yields the unconditional guarantee
$\Prob(S_{\mathrm{new}}\le \hat\rho_\tau)\ge \tau$, equivalently
$\Prob(U_{\mathrm{new}}\in \cU_{\hat{\btheta},\hat\rho_\tau})\ge \tau$.
\end{proof}

\begin{proof}[Proof of Theorem~\ref{thm:consistency-eps} (Gradient Consistency)]
Fix $\varepsilon>0$ and a shape $\btheta\in\Theta$. For brevity, write
\[
S_i:=s_{\btheta}(U_i),\qquad S:=s_{\btheta}(U),
\]
and define the empirical and population smoothed CDFs
\[
\widehat F(r):=\widehat F_{\btheta,\varepsilon}(r)
=\frac{1}{n_{\mathrm{tune}}}\sum_{i=1}^{n_{\mathrm{tune}}}\Phi\!\left(\frac{r-S_i}{\varepsilon}\right),
\qquad
F(r):=F_{\btheta,\varepsilon}(r)
=\E\!\left[\Phi\!\left(\frac{r-S}{\varepsilon}\right)\right].
\]
Let $\rho:=\rho_{P,\varepsilon}(\btheta)$ and $\hat\rho:=\hat\rho_\varepsilon(\btheta)$ denote the corresponding
$\tau$-quantiles (defined via the ``inf'' constructions in the main text).

\textbf{Step 0 (Lipschitz constants).}
Because $\Phi$ is continuously differentiable with bounded derivative $\varphi$ (Assumption~\ref{asm:smoothing}),
both $F$ and $\widehat F$ are globally Lipschitz in $r$ with a deterministic constant
\[
L_F := \frac{\|\varphi\|_\infty}{\varepsilon},
\qquad\text{i.e.,}\qquad
|F(r)-F(r')|\le L_F|r-r'|,\ \ |\widehat F(r)-\widehat F(r')|\le L_F|r-r'|
\ \ \forall r,r'\in\R.
\]

\textbf{Step 1 (Uniform convergence of $\widehat F$ on a neighborhood).}
Fix $\delta>0$ such that $F$ is strictly increasing on $I:=[\rho-\delta,\rho+\delta]$ and
\[
m:=\inf_{r\in I} \partial_r F(r) \ >\ 0,
\]
which is possible by (A3) and continuity of $\partial_rF$ (Lemma~\ref{lem:smoothed-derivatives}).
We show that
\begin{equation}\label{eq:uniform-F}
\sup_{r\in I}|\widehat F(r)-F(r)| \xrightarrow{\Prob} 0.
\end{equation}
To prove~\eqref{eq:uniform-F}, fix $\eta>0$ and choose a grid $r_0,\ldots,r_M$ on $I$ with mesh size
$\max_k|r_{k+1}-r_k|\le h$, where $h:=\eta/(4L_F)$.
For any $r\in I$, pick $r_k$ with $|r-r_k|\le h$ and use Lipschitzness:
\[
|\widehat F(r)-F(r)|
\le |\widehat F(r_k)-F(r_k)| + |\widehat F(r)-\widehat F(r_k)| + |F(r)-F(r_k)|
\le |\widehat F(r_k)-F(r_k)| + 2L_F h.
\]
Taking sup over $r\in I$ yields
\[
\sup_{r\in I}|\widehat F(r)-F(r)|
\le \max_{k=0,\ldots,M} |\widehat F(r_k)-F(r_k)| + 2L_F h
\le \max_{k} |\widehat F(r_k)-F(r_k)| + \eta/2.
\]
For each fixed grid point $r_k$, the summands are bounded and i.i.d., so by the LLN,
$\widehat F(r_k)\to F(r_k)$ in probability. Since $M<\infty$, a union bound implies
$\max_k |\widehat F(r_k)-F(r_k)|\to 0$ in probability. Hence the RHS converges in probability to $\eta/2$,
and since $\eta>0$ was arbitrary, we obtain~\eqref{eq:uniform-F}.

\textbf{Step 2 (Consistency of the smoothed quantile $\hat\rho$).}
We show $\hat\rho\to \rho$ in probability. Let $\eta\in(0,\delta)$.
By the mean value theorem and the definition of $m$,
\[
F(\rho+\eta)\ge F(\rho)+m\eta=\tau+m\eta,
\qquad
F(\rho-\eta)\le F(\rho)-m\eta=\tau-m\eta.
\]
On the event $\sup_{r\in I}|\widehat F(r)-F(r)|\le m\eta/2$, we have
\[
\widehat F(\rho+\eta)\ge F(\rho+\eta)-m\eta/2 \ge \tau+m\eta/2>\tau,
\qquad
\widehat F(\rho-\eta)\le F(\rho-\eta)+m\eta/2 \le \tau-m\eta/2<\tau.
\]
Since $\widehat F$ is nondecreasing, the definition $\hat\rho=\inf\{r:\widehat F(r)\ge\tau\}$ implies
$\rho-\eta \le \hat\rho \le \rho+\eta$ on this event. Therefore
\[
\Prob(|\hat\rho-\rho|>\eta) \le \Prob\!\left(\sup_{r\in I}|\widehat F(r)-F(r)|>m\eta/2\right)\xrightarrow{\ }0
\]
by~\eqref{eq:uniform-F}. This proves $\hat\rho\xrightarrow{\Prob}\rho$.

\textbf{Step 3 (Consistency of the tuned quantile sensitivity estimator).}
Define the weight function and its modulus of continuity:
\[
\omega_r(u):=\varphi\!\left(\frac{r-s_{\btheta}(u)}{\varepsilon}\right),
\qquad
\Omega(\delta):=\sup_{|t-t'|\le\delta}|\varphi(t)-\varphi(t')|,
\]
so $\Omega(\delta)\downarrow 0$ as $\delta\downarrow 0$ by uniform continuity of $\varphi$
(Assumption~\ref{asm:smoothing}).

Define the empirical numerator and denominator at radius $r$:
\[
N_n(r):=\frac{1}{n_{\mathrm{tune}}}\sum_{i=1}^{n_{\mathrm{tune}}}\omega_r(U_i)\,\nabla_{\btheta}s_{\btheta}(U_i),
\qquad
D_n(r):=\frac{1}{n_{\mathrm{tune}}}\sum_{i=1}^{n_{\mathrm{tune}}}\omega_r(U_i),
\]
and the corresponding population quantities
\[
N(r):=\E[\omega_r(U)\,\nabla_{\btheta}s_{\btheta}(U)],
\qquad
D(r):=\E[\omega_r(U)].
\]
Then the tuned estimator in~\eqref{eq:rhohat-grad} equals $N_n(\hat\rho)/D_n(\hat\rho)$.

\emph{(i) LLN at fixed $r=\rho$.}
By Assumption~\ref{asm:score-diff} and boundedness of $\varphi$, the integrable domination
$\|\omega_\rho(U)\nabla_{\btheta}s_{\btheta}(U)\|\le \|\varphi\|_\infty M(U)$ holds.
Hence by the LLN,
\[
N_n(\rho)\xrightarrow{\Prob} N(\rho),
\qquad
D_n(\rho)\xrightarrow{\Prob} D(\rho).
\]

\emph{(ii) Stability under random $r=\hat\rho$.}
For each $i$,
\[
|\omega_{\hat\rho}(U_i)-\omega_{\rho}(U_i)|
=
\left|
\varphi\!\left(\frac{\hat\rho-S_i}{\varepsilon}\right)
-\varphi\!\left(\frac{\rho-S_i}{\varepsilon}\right)
\right|
\le \Omega\!\left(\frac{|\hat\rho-\rho|}{\varepsilon}\right),
\]
because the two arguments differ by exactly $(\hat\rho-\rho)/\varepsilon$.
Therefore,
\[
|D_n(\hat\rho)-D_n(\rho)|
\le \Omega\!\left(\frac{|\hat\rho-\rho|}{\varepsilon}\right),
\]
and similarly
\[
\|N_n(\hat\rho)-N_n(\rho)\|
\le \Omega\!\left(\frac{|\hat\rho-\rho|}{\varepsilon}\right)\cdot
\frac{1}{n_{\mathrm{tune}}}\sum_{i=1}^{n_{\mathrm{tune}}}\|\nabla_{\btheta}s_{\btheta}(U_i)\|.
\]
By Step 2, $|\hat\rho-\rho|\to 0$ in probability, hence
$\Omega(|\hat\rho-\rho|/\varepsilon)\to 0$ in probability.
Also, by Assumption~\ref{asm:score-diff} and the LLN,
$\frac{1}{n_{\mathrm{tune}}}\sum_{i=1}^{n_{\mathrm{tune}}}\|\nabla_{\btheta}s_{\btheta}(U_i)\|
\to \E[\|\nabla_{\btheta}s_{\btheta}(U)\|] < \infty$ in probability.
Thus $D_n(\hat\rho)-D_n(\rho)\to 0$ and $N_n(\hat\rho)-N_n(\rho)\to 0$ in probability.
Combining with (i) yields
\[
N_n(\hat\rho)\xrightarrow{\Prob} N(\rho),
\qquad
D_n(\hat\rho)\xrightarrow{\Prob} D(\rho).
\]

\emph{(iii) Denominator positivity and ratio convergence.}
By Lemma~\ref{lem:smoothed-derivatives},
$\partial_r F(\rho) = \frac{1}{\varepsilon}\E[\omega_\rho(U)] = \frac{1}{\varepsilon}D(\rho)$.
By (A3), $\partial_rF(\rho)>0$, hence $D(\rho)>0$.
Therefore, by the continuous mapping theorem,
\[
\widehat{\nabla_{\btheta}\rho_\varepsilon}(\btheta)
=\frac{N_n(\hat\rho)}{D_n(\hat\rho)}
\xrightarrow{\Prob}
\frac{N(\rho)}{D(\rho)}
=\nabla_{\btheta}\rho_{P,\varepsilon}(\btheta),
\]
where the last equality is Lemma~\ref{lem:smoothed-quantile-deriv}.

\textbf{Step 4 (Continuity of envelope components at $\hat\rho$).}
Define the (deterministic) envelope terms
\[
H(r):=\sum_{j=1}^m \mu_j^*(\btheta,r)\,\nabla_{\btheta}\sigma_{\cU_{\btheta,r}}(\bw_j),
\qquad
G(r):=\sum_{j=1}^m \mu_j^*(\btheta,r)\,\sigma_{\cU_{\btheta,1}}(\bw_j).
\]
By (A4)--(A5), $\mu^*(\btheta,r)$ and $\nabla_{\btheta}\sigma_{\cU_{\btheta,r}}(\bw_j)$ are continuous in $r$
in a neighborhood of $\rho$, hence $H$ and $G$ are continuous at $\rho$.
By Step 2, $\hat\rho\to\rho$ in probability, so
\[
H(\hat\rho)\xrightarrow{\Prob} H(\rho),
\qquad
G(\hat\rho)\xrightarrow{\Prob} G(\rho).
\]

\textbf{Step 5 (Combine to obtain gradient consistency).}
Recall the estimator (written here in the shorthand above)
\[
\hat{\bg}_\varepsilon(\btheta)
=H(\hat\rho)+G(\hat\rho)\cdot \widehat{\nabla_{\btheta}\rho_\varepsilon}(\btheta).
\]
By Step 3 and Step 4 and Slutsky's theorem,
\[
\hat{\bg}_\varepsilon(\btheta)
\xrightarrow{\Prob}
H(\rho)+G(\rho)\cdot \nabla_{\btheta}\rho_{P,\varepsilon}(\btheta).
\]
Under (A4), the robust value function is differentiable and the dual optimizer is unique, so by
Theorem~\ref{thm:envelope} we have
\[
\nabla_{\btheta}V(\btheta,\rho)=H(\rho),
\qquad
\partial_\rho V(\btheta,\rho)=G(\rho).
\]
Moreover, $\rho_{P,\varepsilon}(\btheta)$ is differentiable with gradient
$\nabla_{\btheta}\rho_{P,\varepsilon}(\btheta)$ given by Lemma~\ref{lem:smoothed-quantile-deriv},
so the chain rule yields
\[
\nabla_{\btheta}J_{P,\varepsilon}(\btheta)
=\nabla_{\btheta}V(\btheta,\rho)+\partial_\rho V(\btheta,\rho)\cdot \nabla_{\btheta}\rho_{P,\varepsilon}(\btheta)
=H(\rho)+G(\rho)\cdot \nabla_{\btheta}\rho_{P,\varepsilon}(\btheta).
\]
Thus $\hat{\bg}_\varepsilon(\btheta)\xrightarrow{\Prob}\nabla_{\btheta}J_{P,\varepsilon}(\btheta)$.
\end{proof}

\begin{corollary}[Coverage Preserved Under Tuned Training]\label{cor:coverage-preserved}
Under Assumption~\ref{asm:exchange}, let $\hat{\btheta}$ be computed using $\cD_{\text{train}}$ and $\cD_{\text{tune}}$ only (independent of $\cD_{\text{cal}}$). Compute $\hat{\rho}_\tau$ on $\cD_{\text{cal}}$ using~\eqref{eq:conformal-rho} with shape $\hat{\btheta}$. Then
$\Prob(U_{\text{new}} \in \cU_{\hat{\btheta}, \hat{\rho}_\tau}) \geq \tau$.
\end{corollary}

\begin{proof}
Condition on $\hat{\btheta}$. By construction, $\hat{\btheta}$ is independent of $\cD_{\text{cal}}$.
Applying Theorem~\ref{thm:conformal} conditional on $\hat{\btheta}$ yields the result.
\end{proof}

\section{Ellipsoidal Computation Details}
\label{app:ellipsoidal}

\begin{proposition}[Support Function for Ellipsoids]\label{prop:ellipsoid-support}
For ellipsoid $\cU_{\bL,\rho}$:
$\sigma_{\cU_{\bL,\rho}}(\bw) = \rho \norm{\bL^\top \bw}_2$.
\end{proposition}

\begin{proof}
By change of variables $\bm{v} = \bL^{-1}\bu$:
$\sigma_{\cU_{\bL,\rho}}(\bw)
= \sup_{\norm{\bm{v}}_2 \leq \rho} \ip{\bw}{\bL\bm{v}}
= \sup_{\norm{\bm{v}}_2 \leq \rho} \ip{\bL^\top\bw}{\bm{v}}
= \rho \norm{\bL^\top\bw}_2$.
\end{proof}

\begin{proposition}[Ellipsoidal Gradients]\label{prop:ellipsoid-grads}
Fix $\rho>0$. Consider the ellipsoidal gauge $s_{\bL}(\bu)=\|\bL^{-1}\bu\|_2$ and support function
$\sigma_{\cU_{\bL,\rho}}(\bw)=\rho\|\bL^\top\bw\|_2$.
All matrix gradients below are taken with respect to the Frobenius inner product
$\ipF{A}{B}:=\tr(A^\top B)$.

For $\bw\neq 0$ with $\bL^\top\bw\neq 0$,
\[
\nabla_{\bL}\,\sigma_{\cU_{\bL,\rho}}(\bw)
=\rho\,\frac{\bw(\bL^\top\bw)^\top}{\|\bL^\top\bw\|_2}
=\rho\,\frac{\bw\bw^\top\bL}{\|\bL^\top\bw\|_2}.
\]
For $\bw=0$, $\nabla_{\bL}\sigma_{\cU_{\bL,\rho}}(\bw)=0$.

For $\bu\neq 0$ with $\bL^{-1}\bu\neq 0$,
\[
\nabla_{\bL}\,s_{\bL}(\bu)
=-\,\frac{\bL^{-\top}(\bL^{-1}\bu)(\bL^{-1}\bu)^\top}{\|\bL^{-1}\bu\|_2}.
\]
At $\bu=0$, $s_{\bL}(\bu)$ is not differentiable, but $0$ is a valid choice of subgradient; in implementations we set $\nabla_{\bL}s_{\bL}(0)=0$.
\end{proposition}

\begin{proof}
Let $y(\bL):=\bL^\top\bw$. Then $\sigma_{\cU_{\bL,\rho}}(\bw)=\rho\|y(\bL)\|_2$.
For $\bL^\top\bw\neq 0$, the differential is
\[
\mathrm{d}\sigma
=\rho\,\frac{y^\top}{\|y\|_2}\,\mathrm{d}y
=\rho\,\frac{(\bL^\top\bw)^\top}{\|\bL^\top\bw\|_2}\,(\mathrm{d}\bL)^\top\bw
=\rho\,\ipF{\frac{\bw(\bL^\top\bw)^\top}{\|\bL^\top\bw\|_2}}{\mathrm{d}\bL}.
\]
The $\bw=0$ case is immediate since $\sigma_{\cU_{\bL,\rho}}(0)=0$ for all $\bL$.

For the gauge, let $v(\bL):=\bL^{-1}\bu$. Then $s_{\bL}(\bu)=\|v(\bL)\|_2$.
For $v\neq 0$, $\mathrm{d}v = -\bL^{-1}(\mathrm{d}\bL)\bL^{-1}\bu = -\bL^{-1}(\mathrm{d}\bL)v$ and hence
\[
\mathrm{d}s
=\frac{v^\top}{\|v\|_2}\,\mathrm{d}v
=-\frac{v^\top}{\|v\|_2}\,\bL^{-1}(\mathrm{d}\bL)v
=-\ipF{\frac{\bL^{-\top}vv^\top}{\|v\|_2}}{\mathrm{d}\bL}.
\]
\end{proof}

\section{Zonal Reserve Formulation (Decoupled Case)}
\label{app:zonal-reserve}

When transmission constraints are non-binding, the robust optimization problem decouples across zones and the SCED reduces to a simpler angle-based formulation with separable reserve constraints. This appendix presents this special case.

The decision variables are generation dispatch $g_i$ (MW), reserve allocation $r_i\ge 0$ (MW), and voltage angle $\theta_b$ (rad). The objective minimizes total generation and reserve costs:
\begin{equation}\label{eq:sced-obj}
\min_{g, r, \theta} \sum_{i \in \cG} \left(c_i^g g_i + c_i^r r_i\right)
\end{equation}
where $c_i^g$ is the generation cost (\$/MWh) and $c_i^r$ is the reserve cost (\$/MWh).

\textbf{Power Balance at Each Bus:}
\begin{equation}\label{eq:power-balance}
\sum_{i \in \cG_b} g_i - D_b = \sum_{(b,b') \in \cL} B_{bb'}(\theta_b - \theta_{b'}), \quad \forall b \in \cB
\end{equation}
where $B_{bb'} = 1/X_{bb'}$ is the line susceptance and $D_b$ is the load at bus $b$.

\textbf{DC Power Flow Line Limits:}
\begin{equation}\label{eq:line-limits}
-F_\ell^{\max} \leq B_\ell(\theta_{b(\ell)} - \theta_{b'(\ell)}) \leq F_\ell^{\max}, \quad \forall \ell \in \cL
\end{equation}
where $F_\ell^{\max}$ is the thermal limit of line $\ell$.

\textbf{Generator Capacity:}
\begin{equation}\label{eq:gen-capacity}
\underline{g}_i \leq g_i \leq \bar{g}_i - r_i, \quad r_i \geq 0, \quad \forall i \in \cG
\end{equation}

\textbf{Zonal Reserve Requirements.}
For zone $z$ with exposure vector $\bm{e}_z$, the robust reserve requirement is:
\begin{equation}\label{eq:zonal-reserve}
\sum_{i \in \cG_z} r_i \geq R_z^{\min}, \quad \forall z \in \cZ
\end{equation}
where
\begin{equation}\label{eq:reserve-requirement}
R_z^{\min} = \sigma_{\cU_{\bL,\rho}}(\bm{e}_z) = \rho \norm{\bL^\top \bm{e}_z}_2 = \rho \sqrt{\sum_{z'=1}^{d} L_{z'z}^2}.
\end{equation}

Since $R_z^{\min}$ is an explicit function of $(\bL,\rho)$, the gradients of the reserve requirements are available in closed form via Proposition~\ref{prop:ellipsoid-grads}. In particular, gradient computation in this regime does not require differentiating through (or even solving) the dispatch problem---only the closed-form support function and its matrix derivative are needed.

