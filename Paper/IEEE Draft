\section{Methodology}
\label{sec:methodology}

\subsection{Envelope Gradients of $V(\btheta,\rho)$}

Gradients of the robust value function are obtained from optimal dual multipliers without differentiating through the solver.

\begin{assumption}[Support Function Smoothness]\label{asm:sigma-diff}
For each $j$ and $\rho>0$, the map $\btheta\mapsto \sigma_{\cU_{\btheta,\rho}}(\bw_j)$ is continuously differentiable on $\Theta$ with locally bounded gradient.
\end{assumption}

\begin{theorem}[Envelope Gradient Formula]\label{thm:envelope}
Under Assumptions~\ref{asm:gauge}, \ref{asm:slater}, and~\ref{asm:sigma-diff}, fix $(\btheta,\rho)$ with $V(\btheta,\rho)<+\infty$ and let $\bmu^*\in\cM^*(\btheta,\rho)$.

\emph{(a) Shape gradient.}
\begin{equation}\label{eq:env-theta}
\bg_{\btheta}(\btheta,\rho;\bmu^*) := \sum_{j=1}^m \mu_j^* \nabla_{\btheta} \sigma_{\cU_{\btheta,\rho}}(\bw_j) \in \clsubd_{\btheta} V(\btheta,\rho).
\end{equation}
If the dual optimizer is unique, then $V(\cdot,\rho)$ is differentiable at $\btheta$ with gradient~\eqref{eq:env-theta}.

\emph{(b) Radius gradient.}
\begin{equation}\label{eq:env-rho}
g_{\rho}(\btheta,\rho;\bmu^*) := \sum_{j=1}^m \mu_j^*\,\sigma_{\cU_{\btheta,1}}(\bw_j) \in \clsubd_{\rho}V(\btheta,\rho).
\end{equation}
\end{theorem}

\begin{proof}
See Appendix~\ref{app:envelope-proof}. The Lagrange dual decomposes so that only support function terms depend on $(\btheta,\rho)$. Part~(b) uses $\sigma_{\cU_{\btheta,\rho}}(\bw_j)=\rho\,\sigma_{\cU_{\btheta,1}}(\bw_j)$.
\end{proof}

A key advantage of this result is that it avoids differentiating through the optimization solver entirely. Standard approaches require backpropagation through KKT conditions or interior-point iterations, which is computationally expensive and numerically sensitive for large-scale dispatch. The envelope approach extracts gradients directly from the optimal dual multipliers $\bmu^*$---values the solver computes as a byproduct. In power systems terms, $\mu_j^*$ is the \emph{shadow price} of constraint $j$: the marginal dispatch cost increase per MW of additional reserve requirement. The gradient~\eqref{eq:env-theta} thus steers the shape $\btheta$ toward configurations that relax the most costly binding constraints.

\subsection{The True Profiled Gradient}

When the distribution $P$ is known and sufficient regularity holds, the gradient of $J_P(\btheta) = V(\btheta, \rho_P(\btheta))$ follows from the chain rule.

\begin{assumption}[Quantile Regularity]\label{asm:quantile-reg}
The CDF $F_{\btheta}$ is continuously differentiable near $\rho_P(\btheta)$ with strictly positive density $f_{\btheta}(\rho_P(\btheta)) > 0$, and $(\btheta',r) \mapsto F_{\btheta'}(r)$ is $C^1$ near $(\btheta, \rho_P(\btheta))$.
\end{assumption}

Under Assumption~\ref{asm:quantile-reg}, the implicit function theorem yields $\nabla_{\btheta} \rho_P(\btheta) = -\nabla_{\btheta} F_{\btheta}(\rho_P(\btheta)) / f_{\btheta}(\rho_P(\btheta))$ (Lemma~\ref{lem:quantile-deriv}).

\begin{theorem}[True Oracle Gradient]\label{thm:true-oracle-grad}
Under the above assumptions with unique dual optimizer $\bmu^*$,
\begin{equation}\label{eq:true-grad-expanded}
\boxed{
\begin{aligned}
\nabla_{\btheta} J_P(\btheta) &= \underbrace{\sum_{j=1}^m \mu_j^* \nabla_{\btheta} \sigma_{\cU_{\btheta,\rho_P(\btheta)}}(\bw_j)}_{\text{direct shape effect}} \\
&\quad + \underbrace{\left(\sum_{j=1}^m \mu_j^* \sigma_{\cU_{\btheta,1}}(\bw_j)\right) \left(-\frac{\nabla_{\btheta} F_{\btheta}(\rho_P(\btheta))}{f_{\btheta}(\rho_P(\btheta))}\right)}_{\text{quantile-sensitivity correction}}
\end{aligned}
}
\end{equation}
\end{theorem}

The gradient~\eqref{eq:true-grad-expanded} has two terms. The ``direct shape effect'' captures how changing $\btheta$ affects reserve requirements at fixed radius $\rho$. The ``quantile-sensitivity correction'' accounts for the induced shift in $\rho_P(\btheta)$: reshaping the ellipsoid changes which samples lie inside, shifting the $\tau$-quantile. For instance, stretching the ellipsoid in direction $\bw$ moves samples with large $\bw$-components ``inward'' (lower gauge scores), potentially reducing $\rho$. This shape--size coupling is why the full profiled gradient is needed. The correction term depends on $P$ through $\nabla_{\btheta} F_{\btheta}$ and $f_{\btheta}$; when $P$ is unknown, it must be approximated from data.

\subsection{Distribution-Free Conformal Calibration}

When $P$ is unknown, split conformal prediction provides distribution-free coverage using an independent calibration sample.

\begin{assumption}[Calibration Exchangeability]\label{asm:exchange}
Conditional on $\hat{\btheta}$, the calibration sample $(U_1,\ldots,U_{n_{\mathrm{cal}}})$ and the future realization $U_{\mathrm{new}}$ are exchangeable.
\end{assumption}

\begin{theorem}[Split Conformal Coverage]\label{thm:conformal}
Under Assumption~\ref{asm:exchange}, fix any $\hat{\btheta}$ independent of $(U_i)_{i=1}^{n_{\text{cal}}}$. Define calibration scores $S_i = s_{\hat{\btheta}}(U_i)$ with order statistics $S_{(1)} \leq \cdots \leq S_{(n_{\text{cal}})}$, $S_{(n_{\text{cal}}+1)} := +\infty$, and set
\begin{equation}\label{eq:conformal-rho}
k := \lceil (n_{\text{cal}}+1)\tau \rceil, \quad \hat{\rho}_\tau := S_{(k)}.
\end{equation}
Then $\Prob(U_{\text{new}} \in \cU_{\hat{\btheta}, \hat{\rho}_\tau}) \geq \tau$.
\end{theorem}

\begin{proof}
See Appendix~\ref{app:statistical-proofs}. Exchangeability implies a uniform rank argument with randomized tie-breaking.
\end{proof}

In power systems terms, the coverage guarantee $\tau = 0.95$ means that the realized uncertainty will fall within the procured uncertainty set for at least 95\% of future operating hours. Under the model~\eqref{eq:robust}, this is a sufficient condition for reserve adequacy: if $U \in \cU_{\hat{\btheta}, \hat{\rho}_\tau}$, then the dispatch remains feasible. In practice, additional sources of uncertainty (ramping, contingencies, model mismatch) may cause violations even when $U \in \cU$, so set coverage is a sufficient condition for feasibility under the modeled uncertainty, but does not account for other reliability drivers. The guarantee relies on a four-way data split: $\cD_{\text{train}}$ for shape optimization, $\cD_{\text{tune}}$ for quantile sensitivity estimation during gradient computation, $\cD_{\text{cal}}$ for final radius calibration, and $\cD_{\text{test}}$ for out-of-sample evaluation. Independence between $\cD_{\text{tune}}$ and $\cD_{\text{cal}}$ ensures the coverage guarantee holds despite shape optimization. For dependent time-series data, exchangeability may require block-based calibration for rigorous finite-sample validity.

\subsection{Tuning-Based Gradient Approximation}

The data is partitioned into four disjoint sets: $\cD_{\text{train}}$ (optimize shape), $\cD_{\text{tune}}$ (approximate quantile sensitivity), $\cD_{\text{cal}}$ (conformal calibration), and $\cD_{\text{test}}$ (out-of-sample evaluation).

Let $\Phi$ be a smooth CDF kernel with derivative $\varphi := \Phi'$ (Assumption~\ref{asm:smoothing}). For bandwidth $\varepsilon > 0$, define
\begin{align}\label{eq:smoothed-cdf}
F_{\btheta,\varepsilon}(r) &:= \E\left[\Phi\left(\frac{r - s_{\btheta}(U)}{\varepsilon}\right)\right], \notag\\
\rho_{P,\varepsilon}(\btheta) &:= \inf\{r : F_{\btheta,\varepsilon}(r) \geq \tau\}.
\end{align}

Given tuning data $\{U_i\}_{i=1}^{n_{\text{tune}}}$ with scores $S_i(\btheta) = s_{\btheta}(U_i)$ and weights $\omega_i(\btheta) := \varphi((\hat{\rho}_\varepsilon(\btheta) - S_i(\btheta))/\varepsilon)$, the empirical quantile sensitivity is:
\begin{equation}\label{eq:rhohat-grad}
\widehat{\nabla_{\btheta} \rho_\varepsilon}(\btheta) := \frac{\sum_{i=1}^{n_{\text{tune}}} \omega_i(\btheta) \nabla_{\btheta} s_{\btheta}(U_i)}{\sum_{i=1}^{n_{\text{tune}}} \omega_i(\btheta)}.
\end{equation}

The approximate profiled gradient combines envelope terms with tuned quantile sensitivity:
\begin{equation}\label{eq:ghat}
\boxed{
\begin{aligned}
\hat{\bg}_\varepsilon(\btheta) &:= \underbrace{\sum_{j=1}^m \mu_j^* \nabla_{\btheta} \sigma_{\cU_{\btheta,\hat{\rho}_\varepsilon}}(\bw_j)}_{\text{envelope shape term}} \\
&\quad + \underbrace{\left(\sum_{j=1}^m \mu_j^* \sigma_{\cU_{\btheta,1}}(\bw_j)\right)}_{\text{size sensitivity}} \cdot \underbrace{\widehat{\nabla_{\btheta} \rho_\varepsilon}(\btheta)}_{\text{quantile sensitivity}}
\end{aligned}
}
\end{equation}

\begin{theorem}[Consistency]\label{thm:consistency-eps}
Fix $\varepsilon>0$ and $\btheta\in\Theta$. Under standard smoothness, strict positivity, and continuity conditions (stated as (A1)--(A5) in Appendix~\ref{app:statistical-proofs}),
\[
\hat{\bg}_\varepsilon(\btheta)\ \xrightarrow{\ \Prob\ }\ \nabla_{\btheta}J_{P,\varepsilon}(\btheta) \quad \text{as } n_{\mathrm{tune}}\to\infty.
\]
\end{theorem}

\begin{proof}
See Appendix~\ref{app:statistical-proofs}.
\end{proof}

\begin{remark}
Assumption (A1) in Appendix~\ref{app:statistical-proofs} requires i.i.d.\ tuning samples. The VAR(1) data in Section~\ref{sec:application} violates this; the consistency result applies to i.i.d.\ settings, and the experiment serves as an applied stress test under temporal dependence.
\end{remark}

\subsection{Ellipsoidal Specialization}

Let $\btheta = \bL \in \R^{d \times d}$ be a lower-triangular Cholesky factor with positive diagonal. The ellipsoidal gauge and support functions are:
\begin{equation}
s_{\bL}(\bu) = \norm{\bL^{-1} \bu}_2, \quad
\sigma_{\cU_{\bL,\rho}}(\bw) = \rho \norm{\bL^\top \bw}_2.
\end{equation}
The matrix gradients are (Proposition~\ref{prop:ellipsoid-grads} in Appendix~\ref{app:ellipsoidal}):
\begin{equation}\label{eq:grad-sigma-L}
\nabla_{\bL}\,\sigma_{\cU_{\bL,\rho}}(\bw) = \rho\,\frac{\bw\bw^\top\bL}{\|\bL^\top\bw\|_2}, \quad
\nabla_{\bL}\,s_{\bL}(\bu) = -\,\frac{\bL^{-\top}(\bL^{-1}\bu)(\bL^{-1}\bu)^\top}{\|\bL^{-1}\bu\|_2}.
\end{equation}
For numerical stability, a trace normalization constraint $\tr(\bL\bL^\top) = d$ is imposed via projection after each gradient step.

